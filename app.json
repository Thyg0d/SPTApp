            "title": {
              "en": "Realtime departure"
            },
            "example": {
              "en": "14:37"
            }
          },
          {
            "name": "line_name",
            "type": "string",
            "title": {
              "en": "Line"
            },
            "example": {
              "en": "14"
            }
          },
          {
            "name": "direction",
            "type": "string",
            "title": {
