            "title": {
              "en": "Minutes until departure"
            },
            "example": 8
          },
          {
            "name": "stop_name",
            "type": "string",
            "title": {
              "en": "Stop name"
            },
            "example": {
              "en": "Odenplan"
            }
          },
          {
            "name": "operator",
            "type": "string",
            "title": {
              "en": "Operator"
            },
            "example": {
              "en": "Keolis"
            }
          },
          {
            "name": "origin",
            "type": "string",
            "title": {
              "en": "Origin"
            },
            "example": {
              "en": "Järfälla"
            }
          }
        ]
      }
