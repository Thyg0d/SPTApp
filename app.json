          },
          {
            "name": "destination",
            "type": "string",
            "title": {
              "en": "Destination"
            },
            "example": {
              "en": "Centralstationen"
            }
          },
          {
            "name": "transport_type",
            "type": "string",
            "title": {
              "en": "Transport type"
            },
            "example": {
              "en": "TRAIN"
            }
          },
          {
            "name": "platform",
            "type": "string",
            "title": {
              "en": "Platform / track"
