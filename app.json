    "conditions": [
      {
        "id": "is_delayed",
        "title": {
          "en": "Next departure !{{is}} delayed"
        },
        "hint": {
          "en": "True when the next departure has a known positive delay."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=transport-board"
          }
        ]
      },
      {
        "id": "is_within_minutes",
        "title": {
          "en": "Next departure !{{is}} within {{minutes}} minutes"
        },
        "titleFormatted": {
          "en": "Next departure !{{is}} within [[minutes]] minutes"
        },
        "hint": {
          "en": "True when the countdown to the next departure is at or below the number of minutes you specify."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=transport-board"
          },
          {
            "type": "number",
            "name": "minutes",
            "title": {
              "en": "Minutes"
            },
            "min": 1,
            "max": 120,
            "placeholder": {
              "en": "e.g. 15"
            }
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "refresh_now",
        "title": {
          "en": "Refresh departure data"
        },
        "titleFormatted": {
          "en": "Refresh departure data on [[device]]"
        },
        "hint": {
          "en": "Immediately fetch fresh data from Trafiklab, outside the normal polling schedule."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=transport-board"
          }
        ]
      },
      {
        "id": "set_monitoring",
        "title": {
          "en": "Enable or disable monitoring"
        },
        "titleFormatted": {
          "en": "Turn monitoring [[enabled]]"
        },
        "hint": {
          "en": "Pause monitoring to stop polling Trafiklab (saves API quota). Resume to start polling again."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=transport-board"
          },
          {
            "type": "dropdown",
            "name": "enabled",
            "title": {
              "en": "Monitoring"
            },
            "values": [
              {
                "id": "true",
                "label": {
                  "en": "on"
                }
              },
              {
                "id": "false",
                "label": {
                  "en": "off"
                }
              }
            ]
          }
        ]
      }
