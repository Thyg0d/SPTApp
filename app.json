            "example": 5
          },
          {
            "name": "delay_text",
            "type": "string",
            "title": {
              "en": "Delay text"
            },
            "example": {
              "en": "+5 min late"
            }
          },
          {
            "name": "is_cancelled",
            "type": "boolean",
            "title": {
              "en": "Is cancelled"
            },
            "example": false
