          "en": "A departure is delayed"
        },
        "titleFormatted": {
          "en": "A departure is delayed by at least [[min_delay_minutes]] minutes"
        },
        "hint": {
          "en": "Fires when a delay is first detected, or when the delay grows. The minimum delay threshold lets you ignore small delays."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=transport-board"
          },
          {
            "type": "number",
            "name": "min_delay_minutes",
            "title": {
              "en": "Minimum delay (minutes)"
            },
            "min": 1,
            "max": 60,
            "placeholder": {
              "en": "e.g. 1"
            }
          }
        ],
        "tokens": [
          {
            "name": "departure_time",
            "type": "string",
            "title": {
